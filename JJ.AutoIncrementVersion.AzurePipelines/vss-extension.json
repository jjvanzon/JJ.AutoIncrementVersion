    },
    "files": [
        {
            "path": "ReadBuildNumTask"
        }
    ],
    "contributions": [
        {
            "id": "read-build-num-task",
            "type": "ms.vss-distributed-task.task",
            "targets": [
                "ms.vss-distributed-task.tasks"
            ],
            "properties": {
                "name": "ReadBuildNumTask"
            }
        }
    ]
